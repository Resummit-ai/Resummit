# Database
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth)
# Generate with: npx auth secret
AUTH_SECRET=""

# GitHub OAuth
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# AI Models
# PRIMARY: Gemini (required for production)
# Get key: https://aistudio.google.com/apikey
# Prices: gemini-1.5-flash is ~$0.075 per 1M tokens
GEMINI_API_KEY=""

# FALLBACK: Ollama (local development fallback)
# Install: brew install ollama && ollama pull llama3.2
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# Redis (Upstash) — required for rate limiting & AI budgets
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Token Encryption — REQUIRED for production
# Generate: openssl rand -hex 32
# WARNING: Changing this key invalidates all stored tokens (users must re-auth)
TOKEN_ENCRYPTION_KEY=""

# AI Usage Budget — free tier daily call limit per user (default: 10)
AI_DAILY_LIMIT_PER_USER="10"

# PostHog — product analytics (free tier: 1M events/month)
# Sign up: https://posthog.com → get Project API Key
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Resend — email sending (free tier: 3,000 emails/month)
# Sign up: https://resend.com → get API Key
RESEND_API_KEY=""

# Admin email — your email, used to guard /api/admin/* routes
ADMIN_EMAIL="adelmuhammed786@gmail.com"

